{
  "name": "eslint-plugin-better-cap-config",
  "version": "1.0.0",
  "description": "ESLint plugin to detect deprecated SAP CAP configurations",
  "keywords": [
    "cap-js",
    "cds",
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "sap",
    "sap-cap"
  ],
  "homepage": "https://github.com/mauriciolauffer/eslint-plugin-better-cap-config#readme",
  "bugs": {
    "url": "https://github.com/mauriciolauffer/eslint-plugin-better-cap-config/issues"
  },
  "license": "MIT",
  "author": "Mauricio Lauffer",
  "repository": {
    "type": "git",
    "url": "https://github.com/mauriciolauffer/eslint-plugin-better-cap-config.git"
  },
  "files": [
    "dist/",
    "docs/"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:lint:json": "eslint -c eslint.json-test.config.js",
    "test:ci": "vitest run --reporter=junit --outputFile=./test-results/junit-report.xml",
    "lint": "eslint --cache && oxfmt --check .",
    "lint:fix": "eslint --cache --fix && oxfmt .",
    "lint:ci": "eslint --quiet -f @microsoft/eslint-formatter-sarif -o eslint.sarif",
    "lint:json:stats": "SET TIMING=all && eslint -c eslint.json-test.config.js",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "@humanwhocodes/momoa": "^3.3.10",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-mlauffer-nodejs": "^3.1.1",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "oxfmt": "^0.54.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@eslint/json": ">=1",
    "eslint": ">=9"
  },
  "packageManager": "pnpm@11.5.2"
}
